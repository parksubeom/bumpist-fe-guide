{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "vue"],
  "env": {
    "browser": true
  },
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "dist",
    "dist-ssr",
    "coverage",
    "storybook-static",
    "playwright-report",
    "test-results",
    "**/shared/api/schema.d.ts"
  ]
}
