{
  // In a monorepo, also extend the shared base: use an array
  //   "extends": ["@vue/tsconfig/tsconfig.dom.json", "../../tsconfig.base.json"]
  // For a single package, keep just the Vue DOM config and inline the strict
  // options below.
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // `@vue/tsconfig` already enables `strict: true`. The options below add the
    // extra safety nets we want enforced project-wide (mirrored in tsconfig.base.json).
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
